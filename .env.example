# ─────────────────────────────────────────────────────
# Runtime config
# ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─────────────────────────────────────────────────────
# AI feature (all optional — app works without these)
# ─────────────────────────────────────────────────────

# Set to false to disable the /api/ai/proxy endpoint entirely.
# Default: true (proxy is enabled, users supply their own API keys).
AI_PROXY_ENABLED=true

# NOTE: Do NOT add your own OpenAI / Anthropic / etc. API key here.
# Users provide their own keys in the browser. Keys are stored locally
# in the user's browser and are NEVER saved to the server or logged.

# ─────────────────────────────────────────────────────
# Data update security (optional)
# ─────────────────────────────────────────────────────

# If set, POST /api/data/update requires header: x-update-token: <value>
# Leave blank to allow unauthenticated data updates (fine for local/dev).
# DATA_UPDATE_TOKEN=changeme
